---
import Layout from "../layouts/Layout.astro";
import Clipboard from "../components/Clipboard.astro";
import Social from "../components/Social.astro";
import { CONSTANTS } from "../data/constants";
---

<Layout title="Contáctame · Santos Studio">
	<section slot="main" id="Contacto" class="wrapper">
		<div class="text-section">
			<div class="mono eyebrow">
				<span class="dot"></span> Contacto · ss/05
			</div>
			<h1>¡Hola! Soy <span class="accent">Dani Santos</span>.</h1>
			<p>
				Todo empezó cuando compré mi primera máquina de corte de vinilo
				para hacer pegatinas por hobby. La cosa se fue de las manos:
				la gente empezó a pedirme diseños y aquí seguimos.
			</p>
			<p>
				Con el tiempo aprendí Illustrator y Figma, y ya me manejo
				con proyectos más grandes: rótulos, escaparates, coches enteros.
				Todo cortado y montado por mí.
			</p>
			<p>
				Si tienes una idea rondando la cabeza — desde una pegatina
				para el portátil hasta un vinilo integral — cuéntamela y
				la ponemos en marcha.
			</p>

			<div class="mail-section">
				<span class="mono">EMAIL</span>
				<span class="mail">dani@santos-studio.es</span>
				<div class="clipboard-container">
					<Clipboard />
				</div>
			</div>
		</div>
		<aside class="call-to-action">
			<div class="image-section">
				<div class="corner tl"></div>
				<div class="corner tr"></div>
				<div class="corner bl"></div>
				<div class="corner br"></div>
				<img src="/contact.png" alt="Ilustración de contacto" />
				<span class="mono tag">FIG · 01</span>
			</div>
			<div class="social-links">
				<Social
					link={CONSTANTS.socials.email.url}
					logo={CONSTANTS.socials.email.icon}
					alt="Email"
					filled
				/>
				<Social
					link={CONSTANTS.socials.instagram.url}
					logo={CONSTANTS.socials.instagram.icon}
					alt="Instagram"
					filled
				/>
				<Social
					link={CONSTANTS.socials.github.url}
					logo={CONSTANTS.socials.github.icon}
					alt="Github"
					filled
				/>
				<Social
					link={CONSTANTS.socials.linkedin.url}
					logo={CONSTANTS.socials.linkedin.icon}
					alt="Linkedin"
					filled
				/>
			</div>
		</aside>
	</section>
</Layout>

<style>
	.wrapper {
		width: 100%;
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
		align-items: start;
		gap: 64px;
		padding-top: 24px;
	}

	.text-section {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--paper-dim);
	}
	.eyebrow .dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 10px var(--accent);
	}

	h1 {
		font-size: clamp(2.2rem, 5vw, 3.6rem);
		font-weight: 600;
		letter-spacing: -0.03em;
		line-height: 1.05;
		margin-bottom: 8px;
	}
	.accent {
		color: var(--accent);
	}

	p {
		color: var(--paper-dim);
		font-size: 1.05rem;
		line-height: 1.65;
		max-width: 620px;
	}

	.mail-section {
		margin-top: 20px;
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 14px 18px;
		border: 1px solid var(--line-soft);
		border-radius: 4px;
		background: var(--ink-2);
	}
	.mail-section .mono {
		color: var(--paper-dim);
	}
	.mail {
		flex: 1;
		font-family: var(--font-display);
		color: var(--paper);
		font-size: 1.05rem;
		letter-spacing: 0.01em;
	}
	.clipboard-container {
		display: flex;
	}

	.call-to-action {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: stretch;
		gap: 24px;
		position: sticky;
		top: 96px;
	}

	.image-section {
		position: relative;
		padding: 18px;
		border: 1px solid var(--line-soft);
		background: var(--ink-2);
		border-radius: 4px;
	}
	.image-section img {
		width: 100%;
		display: block;
		border-radius: 3px;
	}
	.image-section .tag {
		position: absolute;
		bottom: 26px;
		left: 26px;
		color: var(--paper);
		background: rgba(10, 22, 66, 0.7);
		padding: 3px 8px;
		border: 1px solid var(--line-soft);
		border-radius: 2px;
	}
	.corner {
		position: absolute;
		width: 14px;
		height: 14px;
		border-color: var(--paper-dim);
		opacity: 0.7;
	}
	.corner.tl {
		top: 6px;
		left: 6px;
		border-top: 1px solid;
		border-left: 1px solid;
	}
	.corner.tr {
		top: 6px;
		right: 6px;
		border-top: 1px solid;
		border-right: 1px solid;
	}
	.corner.bl {
		bottom: 6px;
		left: 6px;
		border-bottom: 1px solid;
		border-left: 1px solid;
	}
	.corner.br {
		bottom: 6px;
		right: 6px;
		border-bottom: 1px solid;
		border-right: 1px solid;
	}

	.social-links {
		display: flex;
		gap: 10px;
	}

	@media (max-width: 900px) {
		.wrapper {
			grid-template-columns: 1fr;
			gap: 40px;
		}
		.call-to-action {
			position: static;
		}
	}
</style>
