---
interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: "website" | "article";
	structuredData?: unknown;
}

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { CONSTANTS } from "../data/constants";

const {
	title,
	description = CONSTANTS.webdata.description,
	image = "/og-image.png",
	type = "website",
	structuredData,
} = Astro.props;

const siteName = CONSTANTS.webdata.title;
const fullTitle = title
	? `${title} · ${siteName}`
	: `${siteName} · Diseño y corte de vinilo`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://santos-studio.es").toString();
const ogImageURL = new URL(image, Astro.site ?? "https://santos-studio.es").toString();

const defaultLd = {
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"@id": "https://santos-studio.es/#business",
	name: siteName,
	description: CONSTANTS.webdata.description,
	url: "https://santos-studio.es",
	image: ogImageURL,
	email: "dani@santos-studio.es",
	priceRange: "€€",
	address: {
		"@type": "PostalAddress",
		addressCountry: "ES",
		addressRegion: "Madrid",
	},
	areaServed: {
		"@type": "Country",
		name: "España",
	},
	founder: {
		"@type": "Person",
		name: CONSTANTS.webdata.author,
	},
	sameAs: [
		CONSTANTS.socials.instagram.url,
		CONSTANTS.socials.linkedin.url,
		CONSTANTS.socials.github.url,
	],
	makesOffer: [
		{ "@type": "Offer", name: "Rótulos y carteles" },
		{ "@type": "Offer", name: "Rotulación de vehículos" },
		{ "@type": "Offer", name: "Vinilos personalizados" },
	],
};

const ld = structuredData ?? defaultLd;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#0a1642" />
		<meta name="color-scheme" content="dark" />

		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<meta name="author" content={CONSTANTS.webdata.author} />
		<meta name="keywords" content={CONSTANTS.webdata.keywords} />
		<link rel="canonical" href={canonicalURL} />

		<meta property="og:type" content={type} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="es_ES" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={fullTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="alternate icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/favicon.png" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
		/>

		<script type="application/ld+json" set:html={JSON.stringify(ld)} />
	</head>
	<body>
		<div class="bg-grid" aria-hidden="true"></div>
		<Header />
		<section class="hero">
			<slot name="hero" />
		</section>
		<main>
			<slot name="main" />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		--ink: #0a1642;
		--ink-2: #0e1c56;
		--ink-3: #142575;
		--line: #7fb3ff;
		--line-soft: rgba(127, 179, 255, 0.16);
		--line-softer: rgba(127, 179, 255, 0.08);
		--paper: #eef4ff;
		--paper-dim: #b6c4e6;
		--accent: #ff5b3a;
		--accent-2: #ffd166;
		--nav-height: 64px;
		--font-display: "Space Grotesk", system-ui, sans-serif;
		--font-mono: "JetBrains Mono", ui-monospace, monospace;
	}

	*,
	*::before,
	*::after {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
		background: var(--ink);
	}

	body {
		background: var(--ink);
		color: var(--paper);
		font-family: var(--font-display);
		font-size: 17px;
		line-height: 1.55;
		font-weight: 400;
		display: flex;
		flex-direction: column;
		align-items: center;
		overflow-x: hidden;
		position: relative;
		min-height: 100vh;
	}

	::selection {
		background: var(--accent);
		color: var(--ink);
	}

	.bg-grid {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		background-image:
			linear-gradient(var(--line-soft) 1px, transparent 1px),
			linear-gradient(90deg, var(--line-soft) 1px, transparent 1px),
			linear-gradient(var(--line-softer) 1px, transparent 1px),
			linear-gradient(90deg, var(--line-softer) 1px, transparent 1px);
		background-size:
			120px 120px,
			120px 120px,
			24px 24px,
			24px 24px;
		mask-image: radial-gradient(
			ellipse 100% 80% at 50% 40%,
			#000 40%,
			transparent 90%
		);
	}

	header,
	section.hero,
	main,
	footer {
		position: relative;
		z-index: 1;
	}

	section.hero {
		width: 100%;
		padding-top: var(--nav-height);
	}

	main {
		width: 100%;
		max-width: 1240px;
		padding: 24px 64px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6rem;
		margin-bottom: 4rem;
	}

	h1,
	h2,
	h3 {
		font-family: var(--font-display);
		letter-spacing: -0.02em;
		color: var(--paper);
	}

	.mono {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--paper-dim);
	}

	.rule {
		height: 1px;
		width: 100%;
		background: var(--line-soft);
	}

	@media (max-width: 768px) {
		main {
			padding: 24px 24px;
			gap: 4.5rem;
		}
		body {
			font-size: 16px;
		}
	}
	@media (max-width: 480px) {
		main {
			padding: 24px 16px;
		}
	}
</style>
