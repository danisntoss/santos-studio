---
import Social from "./Social.astro";
import { CONSTANTS } from "../data/constants";

const year = new Date().getFullYear();
---

<footer>
    <div class="content">
        <div class="row top">
            <div class="brand-block">
                <span class="brand-name">Santos Studio.</span>
                <span class="mono">Diseño · corte · vinilo</span>
            </div>
            <div class="socials">
                <Social
                    link={CONSTANTS.socials.email.url}
                    logo={CONSTANTS.socials.email.icon}
                    alt="Email"
                />
                <Social
                    link={CONSTANTS.socials.instagram.url}
                    logo={CONSTANTS.socials.instagram.icon}
                    alt="Instagram"
                />
                <Social
                    link={CONSTANTS.socials.github.url}
                    logo={CONSTANTS.socials.github.icon}
                    alt="Github"
                />
                <Social
                    link={CONSTANTS.socials.linkedin.url}
                    logo={CONSTANTS.socials.linkedin.icon}
                    alt="Linkedin"
                />
            </div>
        </div>
        <div class="row bottom">
            <span class="mono">© {year} · {CONSTANTS.webdata.author}</span>
            <span class="mono">SS/2026 · Rev.1</span>
        </div>
    </div>
</footer>

<style>
    footer {
        width: 100%;
        margin-top: 4rem;
        padding: 40px 24px 24px;
        border-top: 1px solid var(--line-soft);
        background: var(--ink);
    }

    .content {
        width: 100%;
        max-width: 1240px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .row.bottom {
        border-top: 1px solid var(--line-soft);
        padding-top: 16px;
        color: var(--paper-dim);
    }

    .brand-block {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .brand-name {
        font-family: var(--font-display);
        font-size: 1.35rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--paper);
    }

    .socials {
        display: flex;
        gap: 10px;
    }

    @media (max-width: 600px) {
        .row.top {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }
    }
</style>
