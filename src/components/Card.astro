---
import Swiper from "./Swiper.astro";
import type { ImageMetadata } from "astro";

interface Props {
    name: string;
    images: ImageMetadata[];
    description: string;
    tags?: string[];
    category?: string;
}

const { images, name, description, tags = [], category } = Astro.props;
---

<article class="detail">
    <a href="/" class="back mono">← Volver</a>

    <header class="head">
        <div class="labels">
            <span class="mono">
                {category ? `ss/${category.toLowerCase()}` : "ss/proyecto"}
            </span>
            <span class="mono num">{tags.join(" · ")}</span>
        </div>
        <h1>{name}</h1>
        <p>{description}</p>
    </header>

    <div class="stage">
        <div class="corner tl" aria-hidden="true"></div>
        <div class="corner tr" aria-hidden="true"></div>
        <div class="corner bl" aria-hidden="true"></div>
        <div class="corner br" aria-hidden="true"></div>
        <Swiper images={images} label={name} />
    </div>
</article>

<style>
    .detail {
        width: 100%;
        max-width: 1080px;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        padding-top: 24px;
    }

    .back {
        color: var(--paper-dim);
        text-decoration: none;
        letter-spacing: 0.15em;
        transition: color 0.2s ease;
        width: fit-content;
    }
    .back:hover {
        color: var(--paper);
    }

    .head {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .labels {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--line-soft);
        border-bottom: 1px solid var(--line-soft);
        padding: 8px 0;
        color: var(--paper-dim);
    }
    .labels .num {
        color: var(--accent);
    }

    h1 {
        font-size: clamp(2.4rem, 7vw, 4.6rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1;
    }

    p {
        color: var(--paper-dim);
        font-size: 1.05rem;
        max-width: 640px;
        line-height: 1.6;
    }

    .stage {
        position: relative;
        padding: 14px;
        border: 1px solid var(--line-soft);
        background: var(--ink-2);
        border-radius: 4px;
        overflow: hidden;
        min-height: 400px;
    }

    .corner {
        position: absolute;
        width: 14px;
        height: 14px;
        border-color: var(--paper-dim);
        opacity: 0.6;
        z-index: 3;
        pointer-events: none;
    }
    .corner.tl {
        top: 4px;
        left: 4px;
        border-top: 1px solid;
        border-left: 1px solid;
    }
    .corner.tr {
        top: 4px;
        right: 4px;
        border-top: 1px solid;
        border-right: 1px solid;
    }
    .corner.bl {
        bottom: 4px;
        left: 4px;
        border-bottom: 1px solid;
        border-left: 1px solid;
    }
    .corner.br {
        bottom: 4px;
        right: 4px;
        border-bottom: 1px solid;
        border-right: 1px solid;
    }
</style>
