---
interface Props {
    question: string;
    answer: string;
    index?: number;
}

const { question, answer, index } = Astro.props;
const idx = typeof index === "number" ? String(index).padStart(2, "0") : "";
---

<details class="faq">
    <summary>
        {idx && <span class="mono idx">{idx}</span>}
        <span class="q">{question}</span>
        <span class="chev" aria-hidden="true">+</span>
    </summary>
    <div class="answer">
        <p>{answer}</p>
    </div>
</details>

<style>
    .faq {
        width: 100%;
        border-bottom: 1px solid var(--line-soft);
        padding: 20px 4px;
        transition: background 0.2s ease;
    }
    .faq[open] {
        background: rgba(127, 179, 255, 0.03);
    }

    summary {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 16px;
        align-items: center;
        cursor: pointer;
        list-style: none;
        user-select: none;
    }
    summary::-webkit-details-marker {
        display: none;
    }

    .idx {
        color: var(--accent);
    }

    .q {
        font-size: 1.15rem;
        font-weight: 500;
        color: var(--paper);
        letter-spacing: -0.005em;
    }

    .chev {
        font-family: var(--font-mono);
        font-size: 1.3rem;
        color: var(--paper-dim);
        line-height: 1;
        width: 20px;
        text-align: center;
        transition: transform 0.25s ease, color 0.25s ease;
    }
    .faq[open] .chev {
        transform: rotate(45deg);
        color: var(--accent);
    }

    .answer {
        padding: 14px 0 4px 44px;
        color: var(--paper-dim);
        line-height: 1.6;
        max-width: 780px;
    }

    @media (max-width: 640px) {
        summary {
            grid-template-columns: auto 1fr auto;
            gap: 12px;
        }
        .answer {
            padding-left: 32px;
        }
    }
</style>
