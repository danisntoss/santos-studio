---
import Swiper from './Swiper.astro';

interface Props {
    title: string;
    images: string[];
    url: string;
    description: string;
    tags: string[];
}

const { title, images, url, tags, description } = Astro.props;
---

<a class="bento-card" href={url} aria-label={`Ver proyecto ${title}`}>
    <div class="image-container">
        <Swiper images={images} label={title} />
        <div class="corner tl" aria-hidden="true"></div>
        <div class="corner tr" aria-hidden="true"></div>
        <div class="corner bl" aria-hidden="true"></div>
        <div class="corner br" aria-hidden="true"></div>
    </div>
    <div class="text-info">
        <div class="title-row">
            <h3>{title}</h3>
            <span class="arrow" aria-hidden="true">→</span>
        </div>
        {description && <p class="desc">{description}</p>}
        <div class="tags">
            {tags.map((tag, i) => (
                <span class={`tag ${i === 0 ? "tag-primary" : "tag-alt"}`}>
                    {tag}
                </span>
            ))}
        </div>
    </div>
</a>

<style>
    .bento-card {
        --border: 1px solid var(--line-soft);
        width: 100%;
        height: 100%;
        padding: 12px;
        display: flex;
        gap: 16px;
        flex-direction: column;
        border: var(--border);
        background: linear-gradient(180deg, var(--ink-2) 0%, var(--ink) 100%);
        border-radius: 6px;
        text-decoration: none;
        color: var(--paper);
        transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
        position: relative;
        overflow: hidden;
    }

    .bento-card:hover {
        transform: translateY(-4px);
        border-color: var(--paper-dim);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .bento-card:hover .arrow {
        transform: translate(4px, -4px);
        color: var(--accent);
    }

    .image-container {
        position: relative;
        width: 100%;
        flex: 1 1 auto;
        min-height: 240px;
        border-radius: 4px;
        overflow: hidden;
        background: #000;
    }

    .corner {
        position: absolute;
        width: 10px;
        height: 10px;
        border-color: var(--paper);
        opacity: 0.75;
        z-index: 2;
        pointer-events: none;
    }
    .corner.tl {
        top: 6px;
        left: 6px;
        border-top: 1px solid;
        border-left: 1px solid;
    }
    .corner.tr {
        top: 6px;
        right: 6px;
        border-top: 1px solid;
        border-right: 1px solid;
    }
    .corner.bl {
        bottom: 6px;
        left: 6px;
        border-bottom: 1px solid;
        border-left: 1px solid;
    }
    .corner.br {
        bottom: 6px;
        right: 6px;
        border-bottom: 1px solid;
        border-right: 1px solid;
    }

    .text-info {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 8px 8px 4px;
    }

    .title-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 16px;
    }

    h3 {
        font-size: 1.35rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--paper);
    }

    .arrow {
        font-family: var(--font-mono);
        font-size: 1.15rem;
        color: var(--paper-dim);
        transition: transform 0.25s ease, color 0.25s ease;
    }

    .desc {
        font-size: 0.9rem;
        color: var(--paper-dim);
        line-height: 1.5;
    }

    .tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 4px;
    }
    .tag {
        font-family: var(--font-mono);
        padding: 3px 10px;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border-radius: 3px;
        border: 1px solid var(--line-soft);
    }
    .tag-primary {
        color: var(--paper);
    }
    .tag-alt {
        color: var(--accent);
        border-color: rgba(255, 91, 58, 0.35);
    }
</style>
