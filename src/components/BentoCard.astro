---
import Swiper from './Swiper.astro';
import type { ImageMetadata } from 'astro';

interface Props {
    title: string;
    images: ImageMetadata[];
    url: string;
    description: string;
    tags: string[];
    feature?: boolean;
    wide?: boolean;
}

const {
    title,
    images,
    url,
    tags,
    description,
    feature = false,
    wide = false,
} = Astro.props;
---

<a
    class:list={["bento-card", { feature, wide, narrow: !feature && !wide }]}
    href={url}
    aria-label={`Ver proyecto ${title}`}
>
    {feature && (
        <span class="ribbon mono" aria-hidden="true">
            <span class="pin"></span> Destacado
        </span>
    )}
    <div class="image-container">
        <Swiper images={images} label={title} />
        <div class="corner tl" aria-hidden="true"></div>
        <div class="corner tr" aria-hidden="true"></div>
        <div class="corner bl" aria-hidden="true"></div>
        <div class="corner br" aria-hidden="true"></div>
    </div>
    <div class="text-info">
        <div class="title-row">
            <h3>{title}</h3>
            <span class="arrow" aria-hidden="true">→</span>
        </div>
        {description && <p class="desc">{description}</p>}
        <div class="tags">
            {tags.map((tag, i) => (
                <span class={`tag ${i === 0 ? "tag-primary" : "tag-alt"}`}>
                    {tag}
                </span>
            ))}
        </div>
    </div>
</a>

<style>
    .bento-card {
        --border: 1px solid var(--line-soft);
        width: 100%;
        height: 100%;
        padding: 12px;
        display: flex;
        gap: 16px;
        flex-direction: column;
        border: var(--border);
        background: linear-gradient(180deg, var(--ink-2) 0%, var(--ink) 100%);
        border-radius: 6px;
        text-decoration: none;
        color: var(--paper);
        transition: transform 0.25s ease, border-color 0.25s ease,
            box-shadow 0.25s ease;
        position: relative;
        overflow: hidden;
    }

    .bento-card:hover {
        transform: translateY(-4px);
        border-color: var(--paper-dim);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .bento-card:hover .arrow {
        transform: translate(4px, -4px);
        color: var(--accent);
    }

    .bento-card.feature {
        grid-column: 1 / -1;
        border-color: rgba(255, 91, 58, 0.4);
        box-shadow: 0 0 0 1px rgba(255, 91, 58, 0.25),
            0 30px 60px rgba(255, 91, 58, 0.08);
        padding: 14px;
    }

    .bento-card.wide {
        grid-column: span 4;
    }
    .bento-card.narrow {
        grid-column: span 2;
    }

    @media (max-width: 900px) {
        .bento-card.wide,
        .bento-card.narrow {
            grid-column: 1 / -1;
        }
    }

    .ribbon {
        position: absolute;
        top: 20px;
        left: 20px;
        z-index: 3;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        background: var(--accent);
        color: var(--ink);
        border-radius: 3px;
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        font-weight: 600;
    }
    .ribbon .pin {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--ink);
    }

    .image-container {
        position: relative;
        width: 100%;
        flex: 1 1 auto;
        min-height: 240px;
        border-radius: 4px;
        overflow: hidden;
        background: #000;
    }

    .bento-card.feature .image-container {
        min-height: 460px;
    }

    .corner {
        position: absolute;
        width: 10px;
        height: 10px;
        border-color: var(--paper);
        opacity: 0.75;
        z-index: 2;
        pointer-events: none;
    }
    .corner.tl {
        top: 6px;
        left: 6px;
        border-top: 1px solid;
        border-left: 1px solid;
    }
    .corner.tr {
        top: 6px;
        right: 6px;
        border-top: 1px solid;
        border-right: 1px solid;
    }
    .corner.bl {
        bottom: 6px;
        left: 6px;
        border-bottom: 1px solid;
        border-left: 1px solid;
    }
    .corner.br {
        bottom: 6px;
        right: 6px;
        border-bottom: 1px solid;
        border-right: 1px solid;
    }

    .text-info {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 8px 8px 4px;
    }

    .bento-card.feature .text-info {
        padding: 16px 12px 8px;
        gap: 14px;
    }

    .title-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 16px;
    }

    h3 {
        font-size: 1.35rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--paper);
    }

    .bento-card.feature h3 {
        font-size: 2.2rem;
        letter-spacing: -0.02em;
    }

    .arrow {
        font-family: var(--font-mono);
        font-size: 1.15rem;
        color: var(--paper-dim);
        transition: transform 0.25s ease, color 0.25s ease;
    }

    .bento-card.feature .arrow {
        font-size: 1.6rem;
    }

    .desc {
        font-size: 0.9rem;
        color: var(--paper-dim);
        line-height: 1.5;
    }

    .bento-card.feature .desc {
        font-size: 1.05rem;
        max-width: 640px;
    }

    .tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 4px;
    }
    .tag {
        font-family: var(--font-mono);
        padding: 3px 10px;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border-radius: 3px;
        border: 1px solid var(--line-soft);
    }
    .tag-primary {
        color: var(--paper);
    }
    .tag-alt {
        color: var(--accent);
        border-color: rgba(255, 91, 58, 0.35);
    }

    @media (max-width: 900px) {
        .bento-card.feature .image-container {
            min-height: 360px;
        }
        .bento-card.feature h3 {
            font-size: 1.8rem;
        }
    }
</style>
