---
interface Props {
    title: string;
    icon: string;
}

const { title, icon } = Astro.props;
---

<div class="feature">
    <span class="mark" aria-hidden="true">+</span>
    <span>{title}</span>
</div>

<style>
    .feature {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .mark {
        font-family: var(--font-mono);
        color: var(--accent);
        font-weight: 600;
        line-height: 1;
        width: 16px;
        text-align: center;
    }
    span:not(.mark) {
        font-size: 0.95rem;
        color: var(--paper);
        line-height: 1.55;
    }
</style>
