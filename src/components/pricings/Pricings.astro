---
import PricingCard from "./PricingCard.astro";
import { CONSTANTS } from "../../data/constants";
---

<section id="precios" class="pricings">
    <header class="section-head">
        <div class="labels">
            <span class="mono">ss/03 · precios</span>
            <span class="mono num">3 formatos</span>
        </div>
        <h2>Precios claros, sin sorpresas.</h2>
        <p>
            Elige el formato que mejor encaje con tu proyecto.
            Si tienes dudas, escríbeme y lo hablamos.
        </p>
    </header>
    <div class="grid">
        <PricingCard data={CONSTANTS.pricings.basic} />
        <PricingCard data={CONSTANTS.pricings.standard} featured />
        <PricingCard data={CONSTANTS.pricings.premium} />
    </div>
</section>

<style>
    .pricings {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    .section-head {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 720px;
    }

    .labels {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--line-soft);
        border-bottom: 1px solid var(--line-soft);
        padding: 8px 0;
        color: var(--paper-dim);
    }
    .labels .num {
        color: var(--accent);
    }

    h2 {
        font-size: clamp(2rem, 5vw, 3.4rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1;
    }

    p {
        color: var(--paper-dim);
        max-width: 540px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    @media (max-width: 1000px) {
        .grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }
</style>
