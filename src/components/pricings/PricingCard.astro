---
import PricingFeature from "./PricingFeature.astro";
import { CONSTANTS } from "../../data/constants";

interface Props {
    data: {
        title: string;
        icon: string;
        alt: string;
        description: string;
        price: string;
        features: string[];
    };
    featured?: boolean;
}

const { data, featured = false } = Astro.props;
const featureIcon = CONSTANTS.pricings.commonData.featureIcon;
---

<div class:list={["card", { featured }]}>
    {featured && <span class="ribbon mono">recomendado</span>}
    <div class="corner tl" aria-hidden="true"></div>
    <div class="corner br" aria-hidden="true"></div>

    <div class="head">
        <span class="mono kind">{data.title}</span>
        <div class="title">
            <img src={data.icon} alt={data.alt} />
            <h3>{data.title}</h3>
        </div>
        <p class="desc">{data.description}</p>
    </div>

    <div class="content">
        {data.features.map((feature) => (
            <PricingFeature title={feature} icon={featureIcon} />
        ))}
    </div>

    <div class="price">
        <span class="initial mono">desde</span>
        <span class="value">{data.price}</span>
    </div>
</div>

<style>
    .card {
        position: relative;
        width: 100%;
        padding: 28px;
        display: flex;
        flex-direction: column;
        gap: 1.8rem;
        border: 1px solid var(--line-soft);
        border-radius: 6px;
        background: linear-gradient(180deg, var(--ink-2) 0%, var(--ink) 100%);
        transition: transform 0.25s ease, border-color 0.25s ease;
    }
    .card:hover {
        transform: translateY(-4px);
        border-color: var(--paper-dim);
    }
    .card.featured {
        border-color: var(--accent);
        box-shadow: 0 0 0 1px var(--accent), 0 30px 60px rgba(255, 91, 58, 0.15);
    }

    .ribbon {
        position: absolute;
        top: -1px;
        right: 20px;
        transform: translateY(-50%);
        padding: 4px 10px;
        background: var(--accent);
        color: var(--ink);
        border-radius: 2px;
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
    }

    .corner {
        position: absolute;
        width: 10px;
        height: 10px;
        border-color: var(--paper-dim);
        opacity: 0.5;
        pointer-events: none;
    }
    .corner.tl {
        top: 8px;
        left: 8px;
        border-top: 1px solid;
        border-left: 1px solid;
    }
    .corner.br {
        bottom: 8px;
        right: 8px;
        border-bottom: 1px solid;
        border-right: 1px solid;
    }

    .head {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .kind {
        color: var(--paper-dim);
    }

    .title {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .title img {
        width: 28px;
        height: 28px;
        filter: invert(1) brightness(1.2);
    }
    h3 {
        font-size: 1.85rem;
        font-weight: 600;
        letter-spacing: -0.02em;
    }

    .desc {
        min-height: 72px;
        font-size: 0.95rem;
        color: var(--paper-dim);
        line-height: 1.5;
    }

    .content {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
    }

    .price {
        display: flex;
        align-items: baseline;
        justify-content: flex-end;
        gap: 8px;
        border-top: 1px solid var(--line-soft);
        padding-top: 16px;
    }
    .initial {
        color: var(--paper-dim);
    }
    .value {
        font-family: var(--font-display);
        font-size: 2.4rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--paper);
    }
    .featured .value {
        color: var(--accent);
    }
</style>
