---
interface Props {
    link: string;
    logo: string;
    alt: string;
    filled?: boolean;
}

const { link, logo, alt, filled } = Astro.props;
---

<a
    target="_blank"
    href={link}
    rel="noopener noreferrer"
    class:list={["social", { filled }]}
    aria-label={alt}
>
    <img src={logo} alt={alt} />
</a>

<style>
    .social {
        --size: 40px;
        width: var(--size);
        height: var(--size);
        padding: 9px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border: 1px solid var(--line-soft);
        border-radius: 3px;
        cursor: pointer;
        transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
        background: transparent;
    }
    .social.filled {
        background: var(--ink-2);
    }
    .social img {
        width: 100%;
        height: 100%;
        filter: brightness(0) invert(1);
    }
    .social:hover {
        border-color: var(--paper);
        transform: translateY(-2px);
    }
</style>
