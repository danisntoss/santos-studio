---
interface Props {
    images: string[];
}

const { images } = Astro.props;
---

<div class="carousel" data-carousel>
    <div class="track" data-track>
        {
            images.map((image, index) => (
                <figure class="slide">
                    <img src={image} alt={`Imagen ${index + 1}`} loading="lazy" />
                </figure>
            ))
        }
    </div>

    {images.length > 1 && (
        <>
            <button
                type="button"
                class="nav prev"
                data-prev
                aria-label="Anterior"
            >
                ‹
            </button>
            <button
                type="button"
                class="nav next"
                data-next
                aria-label="Siguiente"
            >
                ›
            </button>
            <div class="dots" data-dots>
                {images.map((_, index) => (
                    <button
                        type="button"
                        class="dot"
                        data-dot={index}
                        aria-label={`Ir a imagen ${index + 1}`}
                    />
                ))}
            </div>
            <span class="counter" data-counter>1 / {images.length}</span>
        </>
    )}
</div>

<style>
    .carousel {
        position: relative;
        width: 100%;
        height: 100%;
        min-height: 240px;
        overflow: hidden;
    }

    .track {
        display: flex;
        width: 100%;
        height: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }
    .track::-webkit-scrollbar {
        display: none;
    }

    .slide {
        flex: 0 0 100%;
        width: 100%;
        height: 100%;
        scroll-snap-align: start;
        margin: 0;
    }

    .slide img {
        width: 100%;
        height: 100%;
        min-height: 240px;
        max-height: 460px;
        object-fit: cover;
        display: block;
    }

    .nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 36px;
        height: 36px;
        border-radius: 3px;
        background: rgba(10, 22, 66, 0.7);
        color: var(--paper);
        border: 1px solid var(--line-soft);
        font-size: 1.4rem;
        font-family: var(--font-display);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0;
        transition: opacity 0.2s ease, background 0.2s ease;
        line-height: 1;
        padding: 0;
    }
    .carousel:hover .nav,
    .nav:focus-visible {
        opacity: 1;
    }
    .nav:hover {
        background: var(--ink);
    }
    .nav.prev {
        left: 10px;
    }
    .nav.next {
        right: 10px;
    }

    .dots {
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 6px;
        z-index: 2;
    }
    .dot {
        width: 20px;
        height: 3px;
        border-radius: 2px;
        background: rgba(238, 244, 255, 0.35);
        border: none;
        padding: 0;
        cursor: pointer;
        transition: background 0.2s ease, width 0.2s ease;
    }
    .dot.active {
        background: var(--paper);
        width: 28px;
    }

    .counter {
        position: absolute;
        bottom: 8px;
        right: 10px;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        color: var(--paper);
        background: rgba(10, 22, 66, 0.7);
        padding: 3px 8px;
        border-radius: 3px;
        border: 1px solid var(--line-soft);
        z-index: 2;
    }
</style>

<script>
    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((root) => {
        const track = root.querySelector<HTMLElement>("[data-track]");
        const dots = root.querySelectorAll<HTMLElement>("[data-dot]");
        const counter = root.querySelector<HTMLElement>("[data-counter]");
        const prev = root.querySelector<HTMLElement>("[data-prev]");
        const next = root.querySelector<HTMLElement>("[data-next]");
        if (!track) return;

        const total = track.children.length;
        let current = 0;

        const update = () => {
            const idx = Math.round(track.scrollLeft / track.clientWidth);
            if (idx === current) return;
            current = idx;
            dots.forEach((d, i) => d.classList.toggle("active", i === current));
            if (counter) counter.textContent = `${current + 1} / ${total}`;
        };
        dots.forEach((d, i) => d.classList.toggle("active", i === 0));

        const goTo = (i: number) => {
            const clamped = Math.max(0, Math.min(total - 1, i));
            track.scrollTo({
                left: clamped * track.clientWidth,
                behavior: "smooth",
            });
        };

        track.addEventListener("scroll", () => {
            window.requestAnimationFrame(update);
        });

        dots.forEach((d, i) => {
            d.addEventListener("click", (e) => {
                e.preventDefault();
                e.stopPropagation();
                goTo(i);
            });
        });

        prev?.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();
            goTo(current - 1);
        });
        next?.addEventListener("click", (e) => {
            e.preventDefault();
            e.stopPropagation();
            goTo(current + 1);
        });
    });
</script>
