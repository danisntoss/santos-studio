---
interface Props {
    name?: string;
    link?: string;
    type?: "primary" | "secondary" | "ghost";
    color?: string;
    buttonType?: "button" | "submit" | "reset";
}

const { name, link, type = "primary", color, buttonType } = Astro.props;
---

{
    link ? (
        <a href={link} class={`btn ${type}`} rel="noopener noreferrer">
            <span style={color ? { color } : undefined}>{name}</span>
            <slot />
        </a>
    ) : (
        <button type={buttonType} class={`btn ${type}`}>
            <span style={color ? { color } : undefined}>{name}</span>
            <slot />
        </button>
    )
}

<style>
    .btn {
        --btn-h: 42px;
        border: 1px solid transparent;
        border-radius: 3px;
        padding: 0 16px;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        min-height: var(--btn-h);
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 500;
        letter-spacing: 0.01em;
        text-decoration: none;
        cursor: pointer;
        transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
        background: transparent;
        color: var(--paper);
    }

    .btn span {
        color: inherit;
    }

    .btn.primary {
        background: var(--accent);
        color: var(--ink);
        box-shadow: 0 0 0 1px var(--accent), 0 8px 20px rgba(255, 91, 58, 0.25);
    }
    .btn.primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 0 0 1px var(--accent), 0 12px 28px rgba(255, 91, 58, 0.35);
    }

    .btn.secondary {
        background: transparent;
        color: var(--paper);
        border-color: var(--line-soft);
    }
    .btn.secondary:hover {
        border-color: var(--paper);
        transform: translateY(-2px);
    }

    .btn.ghost {
        background: transparent;
        color: var(--paper-dim);
        padding: 0 8px;
    }
    .btn.ghost:hover {
        color: var(--paper);
    }
</style>
