---
import { projects, categories } from "../data/data";
import BentoCard from "./BentoCard.astro";

const grouped = Object.entries(categories).map(([key, cat]) => ({
    key,
    ...cat,
    items: projects.filter((p) => p.category === key),
}));
---

<section id="vinilos" class="vinilos">
    <header class="section-head">
        <div class="labels">
            <span class="mono">ss/02 · trabajos</span>
            <span class="mono num">
                {String(projects.length).padStart(2, "0")} proyectos
            </span>
        </div>
        <h2>Del boceto al vinilo.</h2>
        <p>
            Cada trabajo diseñado, cortado y montado a mano.
            Divididos por lo que hago: motor y rótulos.
        </p>
    </header>

    {
        grouped.map((cat) => (
            <div id={cat.key} class="category">
                <header class="cat-head">
                    <span class="mono code">{cat.code}</span>
                    <h3>{cat.label}</h3>
                    <span class="mono count">
                        {String(cat.items.length).padStart(2, "0")}
                    </span>
                </header>
                <p class="cat-desc">{cat.description}</p>

                <div class="grid">
                    {(() => {
                        let nfIdx = -1;
                        return cat.items.map((item) => {
                            if (!item.feature) nfIdx += 1;
                            const pos = nfIdx % 4;
                            const wide = pos === 0 || pos === 3;
                            return (
                                <BentoCard
                                    url={`/${item.slug}`}
                                    title={item.name}
                                    images={item.images}
                                    description={item.description}
                                    tags={item.tags}
                                    feature={item.feature}
                                    wide={!item.feature && wide}
                                />
                            );
                        });
                    })()}
                </div>
            </div>
        ))
    }
</section>

<style>
    .vinilos {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 4rem;
    }

    .section-head {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 720px;
    }

    .labels {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--line-soft);
        border-bottom: 1px solid var(--line-soft);
        padding: 8px 0;
        color: var(--paper-dim);
    }
    .labels .num {
        color: var(--accent);
    }

    h2 {
        font-size: clamp(2rem, 5vw, 3.4rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1;
    }

    section > .section-head p {
        color: var(--paper-dim);
        max-width: 540px;
    }

    .category {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .cat-head {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: baseline;
        gap: 20px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--line-soft);
    }
    .cat-head .code {
        color: var(--paper-dim);
    }
    .cat-head h3 {
        font-size: clamp(1.6rem, 3.5vw, 2.4rem);
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1;
    }
    .cat-head .count {
        color: var(--accent);
    }

    .cat-desc {
        color: var(--paper-dim);
        max-width: 640px;
        margin-top: -0.5rem;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        grid-auto-flow: row dense;
        gap: 20px;
    }

    @media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }
    }
</style>
