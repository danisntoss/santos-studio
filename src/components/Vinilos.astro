---
import { data } from "../data/data";
import BentoCard from "./BentoCard.astro";
import Bento from "./Bento.astro";

const projects = data.flat();
---

<section id="vinilos" class="vinilos">
    <header class="section-head">
        <div class="labels">
            <span class="mono">ss/02 · trabajos</span>
            <span class="mono num">{String(projects.length).padStart(2, "0")} proyectos</span>
        </div>
        <h2>Del boceto al vinilo.</h2>
        <p>
            Una selección de trabajos recientes en rótulos, vehículos
            y pequeñas piezas de decoración.
        </p>
    </header>

    {
        data.map((bento) => (
            <Bento>
                <BentoCard
                    slot="slot1"
                    url={`/${bento[0].id}`}
                    title={bento[0].name}
                    images={bento[0].images}
                    description={bento[0].description}
                    tags={bento[0].tags}
                />
                <BentoCard
                    slot="slot2"
                    url={`/${bento[1].id}`}
                    title={bento[1].name}
                    images={bento[1].images}
                    description={bento[1].description}
                    tags={bento[1].tags}
                />
                <BentoCard
                    slot="slot3"
                    url={`/${bento[2].id}`}
                    title={bento[2].name}
                    images={bento[2].images}
                    description={bento[2].description}
                    tags={bento[2].tags}
                />
                <BentoCard
                    slot="slot4"
                    url={`/${bento[3].id}`}
                    title={bento[3].name}
                    images={bento[3].images}
                    description={bento[3].description}
                    tags={bento[3].tags}
                />
            </Bento>
        ))
    }
</section>

<style>
    .vinilos {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    .section-head {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 720px;
    }

    .labels {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--line-soft);
        border-bottom: 1px solid var(--line-soft);
        padding: 8px 0;
        color: var(--paper-dim);
    }
    .labels .num {
        color: var(--accent);
    }

    h2 {
        font-size: clamp(2rem, 5vw, 3.4rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1;
    }

    p {
        color: var(--paper-dim);
        max-width: 540px;
    }
</style>
